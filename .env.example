# ─────────────────────────────────────────────────────────────────────────────
# betterhomes game hub — environment configuration
# Copy to `.env.local` for local dev. Every value below is OPTIONAL: with none
# set, the hub runs against an in-memory store so you can play and demo locally.
# ─────────────────────────────────────────────────────────────────────────────

# Anti-cheat signing secret. MUST be set to a long random string in production.
# Used to sign play-session tokens (HMAC-SHA256). Without it a dev-only default
# is used and a warning is logged.
SCORE_SIGNING_SECRET=

# ── Managed database (Supabase) ──────────────────────────────────────────────
# Leave blank to use the in-memory store (data resets on restart — dev only).
# Set both to persist leaderboards and leads in Supabase Postgres.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── CRM webhook (the point of the build) ─────────────────────────────────────
# Every saved lead is POSTed here as JSON. Leave blank to skip (logged instead).
CRM_WEBHOOK_URL=
# Optional bearer token sent as `Authorization: Bearer <token>` to the webhook.
CRM_WEBHOOK_TOKEN=

# ── Public site URL (for OG share cards + challenge links) ────────────────────
# e.g. https://careers.betterhomes.ae  — defaults to the request origin.
NEXT_PUBLIC_SITE_URL=
